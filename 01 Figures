library(ggplot2)
library(dplyr)

# -----------------------
# BE density function ---
# -----------------------

mu <- 5
sigma_values <- c(1,2,4,10)
x_vals <- seq(0.01,15,length.out = 500)

data <- expand.grid(x=x_vals, sigma=sigma_values) %>%
  mutate(density = dBE(x,mu,sigma))

ggplot(data, aes(x = x, y = density, color = factor(sigma), linetype = factor(sigma))) +
  geom_line(size = 1.2) +
  geom_vline(xintercept = mu, linetype = "dashed", color = "grey", size = 0.5) +
  geom_text(aes(x = mu, y = 0.03, label = "mode"), inherit.aes = FALSE) +
  geom_text(aes(x = mu, y = 0.015, label = "mu == 5"), inherit.aes = FALSE, parse = TRUE) +
  scale_color_manual(name = expression(sigma), values = c("black", "red", "blue", "green")) +
  scale_linetype_manual(name = expression(sigma), values = 1:4) +
  labs(x = "t", y = "Density function") +
  theme_minimal(base_size = 14) +
  theme(
    panel.border = element_rect(color = "black", fill = NA, size = 1.2),
    axis.ticks = element_line(color = "black"),
    axis.title = element_text(size = 18),
    legend.position = c(0.86, 0.8), 
    legend.background = element_rect(fill = "white", color = "black", size = 0.5),
    axis.text = element_text(size = 14)
  )

sigma <- 1
mu_values <- c(1,4,8)

x_vals <- seq(0.01,10,length.out = 500)
data <- expand.grid(x=x_vals, mu=mu_values) %>%
